---
import { Image } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';

import ProfilePicture from '../assets/Douglas_2026.jpg';
import Head from '../components/Head.astro';
import DarkLightController from '../components/ui/DarkLightController.astro';
import Navbar from '../components/ui/Navbar.astro';

import Footer from '../components/ui/Footer.astro';
import { profile, seo, template } from '../settings';

type Props = {
	title?: string
	description?: string
	image?: string
	robots?: string
	keywords?: string
}

const {
	title = seo.default_title,
	description = seo.default_description,
	image = seo.default_image,
	robots = 'index,follow,max-image-preview:large',
	keywords = seo.default_keywords,
} = Astro.props
---

<!doctype html>
<html lang='en'>
	<head>
		{template.transitions && <ClientRouter /> }

		<Head title={title} description={description} image={image} robots={robots} keywords={keywords} />



	</head>
	<body>
		<a
			href='#main-content'
			class='sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-base-100 focus:px-4 focus:py-2 focus:text-base-content focus:ring-2 focus:ring-success'
			data-ui='skip-to-main'
		>
			Skip to main content
		</a>
		<div class={`bg-base-100 drawer lg:drawer-open ${template.menu_left ? 'drawer-end' : ''}`} data-ui='app-shell'>
			<input id='my-drawer' type='checkbox' class='drawer-toggle' data-ui='drawer-toggle' />
			<!-- Drawer content -->
            <div class='drawer-content bg-base-100'>
				<header class='sticky top-0 z-50 border-b border-base-content/10 bg-base-100/95 text-base-content shadow-sm' data-ui='top-header'>
					<nav
						class='w-full px-3 py-3 sm:px-4 lg:px-6 lg:py-4'
						aria-label='Top navigation'
						data-ui='top-nav'
					>
						<div
							class='flex items-center justify-between gap-2.5 rounded-xl border border-base-content/10 bg-base-200/70 px-2.5 py-2 lg:hidden'
							data-ui='mobile-top-brand'
						>
							<div class='flex min-w-0 items-center gap-2'>
								<div class='size-11 shrink-0 rounded-full bg-[linear-gradient(135deg,#2af4ce_0%,#1de2bc_45%,#13c7a3_100%)] p-[2px]'>
									<Image
										src={ProfilePicture}
										alt={`Profile picture of ${profile.fullName}`}
										class='size-full rounded-full object-cover object-[center_22%]'
										data-ui='mobile-top-avatar'
									/>
								</div>
								<div class='min-w-0 leading-tight'>
									<p class='truncate text-[0.91rem] font-semibold text-base-content'>
										{profile.fullName}
									</p>
									<p class='truncate text-[0.68rem] font-medium tracking-[0.03em] text-base-content/70'>
										Senior QA Automation Engineer
									</p>
								</div>
							</div>
							<button
								type='button'
								aria-controls='my-drawer'
								aria-expanded='false'
								class='btn btn-ghost btn-square btn-sm h-9 w-9 border border-success/35 bg-success/12 p-0 text-success shadow-[0_1px_0_rgba(16,185,129,0.22)] hover:bg-success/20 hover:text-success focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-success/40 focus-visible:ring-offset-1 focus-visible:ring-offset-base-100 lg:hidden'
								aria-label='Open sidebar menu'
								data-ui='drawer-open-button'
							>
								<svg
									xmlns='http://www.w3.org/2000/svg'
									fill='none'
									viewBox='0 0 24 24'
									stroke-width='1.9'
									class='size-4.5 stroke-current'
								>
									<path
										stroke-linecap='round'
										stroke-linejoin='round'
										d='M4 6.75h16M4 12h16m-16 5.25h16'></path>
								</svg>
							</button>
						</div>
						<div class='hidden lg:flex lg:items-center lg:justify-end' data-ui='desktop-theme-controls'>
							<DarkLightController />
						</div>
					</nav>
				</header>
                <main id='main-content' tabindex='-1' class='p-8 pt-10 lg:pt-16 lg:max-w-5xl max-w-full mx-auto min-h-screen flex flex-col justify-between' data-ui='main-content'>
					<!-- Page content -->
					<slot />
				<Footer />
				</main>
			</div>
			<!-- Drawer side -->
			<div class='drawer-side z-[70]' data-ui='drawer-side'>
				<label for='my-drawer' aria-label='close sidebar' class='drawer-overlay bg-base-content/35 lg:bg-transparent'
					data-ui='drawer-overlay'
				></label>
				<Navbar />
			</div>
		</div>
		<script is:inline>
			(() => {
				const setupDrawerControls = () => {
					if (typeof window === 'undefined') {
						return
					}

					if (typeof window.__drawerMobileCleanup === 'function') {
						window.__drawerMobileCleanup()
					}

					const drawerToggle = document.getElementById('my-drawer')
					const openButton = document.querySelector('[data-ui="drawer-open-button"]')
					const closeButton = document.querySelector('[data-ui="drawer-close-button"]')

					if (!(drawerToggle instanceof HTMLInputElement)) {
						return
					}

					const syncDrawerState = () => {
						const isMobile = window.matchMedia('(max-width: 1023px)').matches
						document.body.classList.toggle('mobile-drawer-open', isMobile && drawerToggle.checked)

						if (openButton instanceof HTMLElement) {
							openButton.setAttribute('aria-expanded', drawerToggle.checked ? 'true' : 'false')
						}
					}

					const onToggleChange = () => syncDrawerState()
					const onResize = () => syncDrawerState()

					const onOpenClick = (event) => {
						event.preventDefault()
						drawerToggle.checked = true
						syncDrawerState()
					}

					const onCloseClick = (event) => {
						event.preventDefault()
						drawerToggle.checked = false
						syncDrawerState()
						if (openButton instanceof HTMLElement) {
							openButton.focus()
						}
					}

					drawerToggle.addEventListener('change', onToggleChange)
					window.addEventListener('resize', onResize, { passive: true })

					if (openButton instanceof HTMLElement) {
						openButton.addEventListener('click', onOpenClick)
					}

					if (closeButton instanceof HTMLElement) {
						closeButton.addEventListener('click', onCloseClick)
					}

					syncDrawerState()

					window.__drawerMobileCleanup = () => {
						drawerToggle.removeEventListener('change', onToggleChange)
						window.removeEventListener('resize', onResize)

						if (openButton instanceof HTMLElement) {
							openButton.removeEventListener('click', onOpenClick)
						}

						if (closeButton instanceof HTMLElement) {
							closeButton.removeEventListener('click', onCloseClick)
						}
					}
				}

				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', setupDrawerControls, { once: true })
				} else {
					setupDrawerControls()
				}

				document.addEventListener('astro:after-swap', setupDrawerControls)
			})()
		</script>
	</body>
</html>

<style>
	@media (prefers-color-scheme: dark) {
		:root {
			--my-color: #252b30;
		}
	}
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}

	@media (max-width: 1023px) {
		body.mobile-drawer-open {
			overflow: hidden;
			overscroll-behavior: contain;
		}
	}
</style>
