---
import BandcampIcon from "@/assets/social-icons/bandcamp.svg";
import AmazonMusicIcon from "@/assets/social-icons/music/amazonmusic.svg";
import AppleMusicIcon from "@/assets/social-icons/music/applemusic.svg";
import DeezerIcon from "@/assets/social-icons/music/deezer.svg";
import SoundCloudIcon from "@/assets/social-icons/music/soundcloud.svg";
import SpotifyIcon from "@/assets/social-icons/music/spotify.svg";
import YouTubeMusicIcon from "@/assets/social-icons/music/youtubemusic.svg";
import Layout from "@/layouts/Layout.astro";

const musicProfiles = [
  {
    label: "Spotify",
    href: "https://open.spotify.com/intl-es/artist/6y1ZpHe0V6EbFGY2BkxeE5",
    Icon: SpotifyIcon,
  },
  {
    label: "Apple Music",
    href: "https://music.apple.com/us/artist/douglas-fugazi/946512935",
    Icon: AppleMusicIcon,
  },
  {
    label: "SoundCloud",
    href: "https://soundcloud.com/douglasfugazi",
    Icon: SoundCloudIcon,
  },
  {
    label: "Bandcamp",
    href: "https://monofonicos.bandcamp.com/",
    Icon: BandcampIcon,
  },
  {
    label: "YouTube Music",
    href: "https://music.youtube.com/playlist?list=PLO6TwpL0B1h3xG3bEfLVQ8qjTsZPy9-r_",
    Icon: YouTubeMusicIcon,
  },
  {
    label: "Amazon",
    href: "https://music.amazon.com/artists/B00QI0Y1UG/douglas-fugazi",
    Icon: AmazonMusicIcon,
  },
  {
    label: "Deezer",
    href: "https://www.deezer.com/mx/artist/7193220",
    Icon: DeezerIcon,
  },
];
---

<Layout title="Music | Douglas Fugazi">
  <div class="space-y-12 pb-16">
    <!-- Header Section -->
    <section
      class="reveal relative overflow-hidden rounded-2xl border border-success/25 bg-base-200/70 p-6 lg:p-8"
      style="--reveal-delay: 40ms;"
    >
      <div
        class="pointer-events-none absolute -right-10 -top-10 size-40 rounded-full bg-success/10 blur-2xl"
      >
      </div>
      <div
        class="pointer-events-none absolute -bottom-12 -left-12 size-48 rounded-full bg-primary/10 blur-2xl"
      >
      </div>
      <div
        class="pointer-events-none absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-success/20 via-success/70 to-success/20"
      >
      </div>
      <p
        class="text-xs font-semibold uppercase tracking-[0.18em] text-success/80"
      >
        Electronic Music Producer
      </p>
      <h1
        class="mt-4 max-w-4xl text-2xl font-bold text-base-content lg:text-3xl"
      >
        Douglas Fugazi
      </h1>
      <p class="mt-4 max-w-4xl text-lg leading-relaxed text-base-content/80">
        Based in the vibrant city of Medellín, Colombia, Douglas blends
        technology and electronic experimentation within the cultural movement
        that enhances local musical artists. Influenced by Dub Techno,
        characterized by its deep rhythms, rich textures, and immersive
        atmospheres, his role as label manager at <a
          href="https://monofonicos.net/douglas-fugazi/"
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium text-success hover:underline"
          >Monofonicos Netlabel</a
        > has been fundamental to the Latin American scene.
      </p>

      <div class="mt-7">
        <p
          class="text-xs font-semibold uppercase tracking-[0.16em] text-success/80"
        >
          Streaming
        </p>
        <div class="mt-3 flex flex-wrap gap-2.5">
          {
            musicProfiles.map(({ href, label, Icon }) => (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Open ${label} profile`}
                title={label}
                class="group inline-flex items-center gap-2 rounded-full border border-base-300/75 bg-base-100/90 px-3 py-1.5 text-xs font-semibold text-base-content/80 shadow-[0_1px_6px_rgba(0,0,0,0.03)] transition-all duration-300 hover:border-success/35 hover:text-success hover:shadow-[0_6px_18px_rgba(34,197,94,0.12)]"
              >
                <span class="inline-flex size-6 shrink-0 items-center justify-center rounded-full border border-success/20 bg-success/10">
                  <Icon
                    class="size-[13px]"
                    fill="currentColor"
                    aria-hidden="true"
                  />
                </span>
                <span>{label}</span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Content Section -->
    <section class="reveal mt-12" style="--reveal-delay: 100ms;">
      <h2
        class="mb-8 text-center text-2xl font-bold tracking-tight text-base-content lg:text-left"
      >
        Releases & Top Tracks
      </h2>

      <div class="flex flex-col gap-16 lg:gap-20">
        <div
          class="overflow-hidden rounded-[14px] border border-base-300 bg-base-200/50 p-[2px] transition-shadow duration-300 hover:shadow-[0_0_30px_rgba(34,197,94,0.3)] lg:mb-2 lg:p-1"
        >
          <iframe
            data-testid="embed-iframe"
            title="Douglas Fugazi - Spotify Artist Profile"
            class="bg-base-100 block w-full rounded-[10px]"
            style="border-radius: 12px; display: block; border: none; outline: none;"
            src="https://open.spotify.com/embed/artist/6y1ZpHe0V6EbFGY2BkxeE5?utm_source=generator&theme=0"
            width="100%"
            height="352"
            allowfullscreen
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            referrerpolicy="strict-origin-when-cross-origin"
            loading="lazy"
          >
          </iframe>
        </div>

        <div
          class="relative flex items-center justify-center py-1"
          role="group"
          aria-label="Featured releases section divider"
        >
          <div class="h-px w-full bg-base-300/80"></div>
          <div
            class="absolute inline-flex items-center rounded-full border border-base-300/70 bg-base-200 p-1 shadow-sm"
          >
            <span
              class="inline-flex items-center gap-2 rounded-full bg-base-100 px-4 py-1.5 text-xs font-semibold tracking-[0.04em] text-success shadow-[0_2px_8px_rgba(0,0,0,0.06)]"
            >
              <svg
                class="h-4 w-4 shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2.5"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
              Featured Release
            </span>
          </div>
        </div>

        <div
          class="overflow-hidden rounded-[14px] border border-success/25 bg-base-200/50 p-[2px] transition-shadow duration-300 hover:shadow-[0_0_30px_rgba(34,197,94,0.3)] lg:mt-2 lg:p-1"
        >
          <iframe
            title="Douglas Fugazi - Bandcamp Featured Release"
            class="bg-base-100 block w-full rounded-[10px]"
            style="border-radius: 12px; border: 0; outline: none;"
            src="https://bandcamp.com/EmbeddedPlayer/album=1648714062/size=large/bgcol=ffffff/linkcol=2ebd35/artwork=small/transparent=true/"
            width="100%"
            height="472"
            loading="lazy"
            allowfullscreen
            referrerpolicy="strict-origin-when-cross-origin"
            seamless
          >
          </iframe>
        </div>
      </div>
    </section>
  </div>
</Layout>
