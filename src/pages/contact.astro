---
import SocialIcons from "@/components/ui/SocialIcons.astro";
import Layout from "@/layouts/Layout.astro";
import { social } from "@/settings";

const contactEmailHref = social.email
  ? `mailto:${social.email}?subject=Let%27s%20work%20together`
  : "";
---

<Layout
  title="Contact Douglas Urrea Ocampo | QA Automation Consulting"
  description="Contact Douglas Urrea Ocampo for QA automation consulting, AI-driven testing strategy, framework architecture, and quality acceleration services. Open to Work."
>
  <div class="space-y-10 pb-14" data-ui="contact-page">
    <section
      class="reveal relative overflow-hidden rounded-2xl border border-success/25 bg-base-200/70 p-6 lg:p-8"
      style="--reveal-delay: 40ms;"
      data-ui="contact-hero"
    >
      <div
        class="pointer-events-none absolute -right-10 -top-10 size-40 rounded-full bg-success/10 blur-2xl"
      >
      </div>
      <div
        class="pointer-events-none absolute -bottom-12 -left-12 size-48 rounded-full bg-primary/10 blur-2xl"
      >
      </div>
      <div
        class="pointer-events-none absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-success/20 via-success/70 to-success/20"
      >
      </div>

      <p
        class="text-xs font-semibold uppercase tracking-[0.18em] text-success/80"
      >
        Contact
      </p>
      <h1 class="mt-3 text-2xl font-bold text-base-content lg:text-3xl">
        Let's Connect
      </h1>
      <p class="mt-4 max-w-3xl text-lg leading-relaxed text-base-content/80">
        If you are looking for support with Test Automation architecture,
        framework strategy, AI-driven testing, or quality acceleration, this is
        the best place to reach me.
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        {
          contactEmailHref && (
            <a
              href={contactEmailHref}
              class="btn btn-success text-success-content"
              data-ui="contact-email-cta"
            >
              Send an Email
            </a>
          )
        }
        <a
          href={social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-outline btn-success"
          data-ui="contact-linkedin-cta"
        >
          Connect on LinkedIn
        </a>
      </div>

      <div class="mt-6">
        <p
          class="text-xs font-semibold uppercase tracking-[0.16em] text-base-content/65"
        >
          Follow me on
        </p>
        <div class="mt-3">
          <SocialIcons context="contact" />
        </div>
      </div>
    </section>

    <section class="reveal" style="--reveal-delay: 120ms;" data-ui="contact-expectations">
      <div class="grid gap-4 lg:grid-cols-2">
        <article class="rounded-2xl border border-base-300 bg-base-100 p-6 transition-shadow duration-300 hover:border-success/30 hover:shadow-[0_0_30px_rgba(34,197,94,0.3)]">
          <h2 class="text-xl font-semibold text-base-content">
            Preferred Channel
          </h2>
          <p class="mt-3 leading-relaxed text-base-content/75">
            Email is ideal for project details and collaboration requests.
            LinkedIn is great for networking, speaking invites, and professional
            conversations.
          </p>
          <p class="mt-2 leading-relaxed text-base-content/75">
            <strong class="text-success">Yo también hablo Español.</strong>
          </p>
        </article>

        <article class="rounded-2xl border border-base-300 bg-base-100 p-6 transition-shadow duration-300 hover:border-success/30 hover:shadow-[0_0_30px_rgba(34,197,94,0.3)]">
          <h2 class="text-xl font-semibold text-base-content">
            Response Expectations
          </h2>
          <p class="mt-3 leading-relaxed text-base-content/75">
            I usually reply within 24-48 hours. For faster alignment, include
            your project scope, timeline, and current QA challenges in your
            first message.
          </p>
        </article>
      </div>
    </section>
  </div>
</Layout>

<style>
  .reveal {
    animation: contactDropIn 820ms cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: var(--reveal-delay, 0ms);
    will-change: transform, opacity;
  }

  @keyframes contactDropIn {
    from {
      opacity: 0;
      transform: translate3d(0, -10px, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      animation: none;
    }
  }
</style>
