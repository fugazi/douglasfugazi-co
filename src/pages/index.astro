---
import Layout from "../layouts/Layout.astro";

import ProfilePictures from "@/assets/Douglas_2026.jpg";
import CoreSkills from "@/components/ui/CoreSkills.astro";
import Hero from "@/components/ui/Hero.astro";
import { profile, social } from "@/settings";

const { fullName, title, institute, core_skills } = profile;
const contactEmailHref = social.email
  ? `mailto:${social.email}?subject=Let%27s%20Build%20Together`
  : "";
---

<Layout>
  <!-- Hero Section -->
  <section class="flex items-center gap-8 xl:gap-12 border-b pb-12" data-ui="home-hero-section">
    <Hero
      fullName={fullName}
      title={title}
      institute={institute}
      profilePicture={ProfilePictures}
    />
  </section>

  <!-- Core Skills -->
  <section class="py-12 border-b" data-ui="home-core-skills-section">
    <CoreSkills sectionTitle="Core Skills" categories={core_skills} />
  </section>

  <!-- Contact Call To Action -->
  <section class="py-12 border-t" data-ui="home-cta-section">
    <div
      class="relative overflow-hidden rounded-3xl border border-success/30 bg-base-200/80 p-8 lg:p-10"
    >
      <div
        class="pointer-events-none absolute -right-10 -top-10 size-40 rounded-full bg-success/10 blur-2xl"
      >
      </div>
      <div
        class="pointer-events-none absolute -bottom-12 -left-12 size-48 rounded-full bg-primary/10 blur-2xl"
      >
      </div>

      <div class="relative grid gap-8 lg:grid-cols-[1.4fr_1fr] lg:items-center">
        <div>
          <p
            class="text-sm font-semibold uppercase tracking-[0.18em] text-success"
          >
            Open To Collaborate
          </p>
          <h2 class="mt-3 text-3xl font-bold leading-tight text-base-content">
            Let's Build Test Automation Frameworks That Scale
          </h2>
          <p class="mt-4 text-base leading-relaxed text-base-content/80">
            I help teams accelerate delivery with robust automation, AI-assisted
            testing, and quality engineering practices that scale.
          </p>
          <p class="mt-4 text-base leading-relaxed text-base-content/80">
            Stay in touch with me on LinkedIn:
            <a
              href={social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="ml-1 font-semibold text-success underline-offset-4 hover:underline"
              data-ui="home-linkedin-inline"
            >
              https://www.linkedin.com/in/douglasfugazi/
            </a>
          </p>
        </div>

        <div class="rounded-2xl border border-base-300/60 bg-base-100/80 p-6">
          <p class="text-sm font-medium text-base-content/70">Quick Contact</p>
          <p class="mt-2 text-xl font-semibold text-base-content">
            Have a QA challenge?
          </p>
          <p class="mt-2 text-sm text-base-content/70">
            Let's discuss your automation roadmap, framework strategy, or
            quality acceleration.
          </p>

          <div class="mt-5 flex flex-col gap-3">
            {
              contactEmailHref && (
                <a
                  href={contactEmailHref}
                  class="btn btn-success text-success-content"
                  data-ui="home-email-cta"
                >
                  Email Me
                </a>
              )
            }
            <a
              href={social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline btn-success"
              data-ui="home-linkedin-cta"
            >
              Connect on LinkedIn
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
