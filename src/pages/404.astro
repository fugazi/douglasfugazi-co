---
import Layout from '@/layouts/Layout.astro'
---

<Layout
  title="404 | Page Not Found"
  description="The page you are looking for is not available."
  robots="noindex,nofollow,noarchive"
>
  <div class="min-h-[70vh] flex flex-col items-center justify-center text-center" data-ui="not-found-page">
    <h1 class="text-9xl font-black text-base-content mb-4">404</h1>
    <h2 class="text-4xl font-bold text-base-content mb-8">Page Not Found</h2>
      <p class="text-lg text-base-content/80 mb-8">
        Looks like this page went on a coffee break. ☕<br/>
        Even our smartest algorithms couldn't find it!
      </p>
    <div class="flex gap-4">
      <a
        href="/"
        class="btn btn-primary text-primary-content"
        data-ui="not-found-home-link"
      >
        Go Home
      </a>
      <button
        type="button"
        class="btn btn-outline btn-accent"
        onclick="history.back()"
        data-ui="not-found-back-button"
      >
        Go Back
      </button>
    </div>
  </div>
</Layout>
