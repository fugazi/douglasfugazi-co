<script>
  function initTabs() {
    const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
    const tabPanels = document.querySelectorAll('.tab-panel');

    if (!tabBtns.length) return;

    function activateTab(targetBtn: HTMLButtonElement) {
      const allBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
      allBtns.forEach((b) => {
        b.classList.remove('bg-base-100', 'text-success', 'shadow-[0_2px_8px_rgba(0,0,0,0.06)]');
        b.classList.add('text-base-content/70');
        b.setAttribute('aria-selected', 'false');
      });

      targetBtn.classList.add('bg-base-100', 'text-success', 'shadow-[0_2px_8px_rgba(0,0,0,0.06)]');
      targetBtn.classList.remove('text-base-content/70');
      targetBtn.setAttribute('aria-selected', 'true');

      tabPanels.forEach((panel) => {
        panel.classList.add('hidden');
        panel.classList.remove('tab-panel-active');
      });

      const targetId = targetBtn.getAttribute('data-tab');
      const targetPanel = document.getElementById(`panel-${targetId}`);
      if (targetPanel) {
        targetPanel.classList.remove('hidden');
        // Force reflow
        void targetPanel.offsetWidth;
        targetPanel.classList.add('tab-panel-active');
      }
    }

    tabBtns.forEach((btn) => {
      // Create a clone to remove old event listeners from astro view transitions
      const clonedBtn = btn.cloneNode(true) as HTMLButtonElement;
      btn.parentNode?.replaceChild(clonedBtn, btn);

      clonedBtn.addEventListener('click', () => {
        activateTab(clonedBtn);
      });

      clonedBtn.addEventListener('keydown', (event) => {
        const navKeys = ['ArrowRight', 'ArrowLeft', 'Home', 'End'];
        if (!navKeys.includes(event.key)) return;

        event.preventDefault();
        const currentBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.tab-btn'));
        const currentIndex = currentBtns.indexOf(clonedBtn);
        if (currentIndex === -1) return;

        let nextIndex = currentIndex;
        if (event.key === 'ArrowRight') {
          nextIndex = (currentIndex + 1) % currentBtns.length;
        } else if (event.key === 'ArrowLeft') {
          nextIndex = (currentIndex - 1 + currentBtns.length) % currentBtns.length;
        } else if (event.key === 'Home') {
          nextIndex = 0;
        } else if (event.key === 'End') {
          nextIndex = currentBtns.length - 1;
        }

        const nextBtn = currentBtns[nextIndex];
        activateTab(nextBtn);
        nextBtn.focus();
      });
    });
  }

  document.addEventListener('astro:page-load', initTabs);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTabs);
  } else {
    initTabs();
  }
</script>

<style>
  .reveal {
    animation: projectRise 820ms cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: var(--reveal-delay, 0ms);
    will-change: transform, opacity;
  }

  .tab-panel-active {
    animation: tabFadeIn 500ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .float-slow {
    animation: floatY 6s ease-in-out infinite;
  }
  .float-slow-delayed {
    animation: floatY 7s ease-in-out 3.5s infinite;
  }
  .float-x-slow {
    animation: floatX 8s ease-in-out infinite;
  }

  @keyframes floatY {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  @keyframes floatX {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(4px); }
  }

  @keyframes projectRise {
    from {
      opacity: 0;
      transform: translate3d(0, -12px, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @keyframes tabFadeIn {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal,
    .tab-panel-active,
    .float-slow,
    .float-slow-delayed,
    .float-x-slow {
      animation: none !important;
    }
  }
</style>
