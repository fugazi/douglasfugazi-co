---
type BetterIconSize = 'sm' | 'md' | 'lg'

type Props = {
	size?: BetterIconSize
	class?: string
}

const { size = 'md', class: className = '' } = Astro.props as Props

const sizeClassMap: Record<BetterIconSize, string> = {
	sm: 'size-8',
	md: 'size-10',
	lg: 'size-12',
}
---

<div class={`inline-flex items-center justify-center rounded-xl bg-primary/20 text-primary ${sizeClassMap[size]} ${className}`.trim()}>
	<slot />
</div>
