---
import ProfilePictures from '@/assets/Douglas_2026.jpg'
import { template } from '@/settings'
import { Image } from 'astro:assets'
import { profile } from '../../settings'
import SocialIcons from './SocialIcons.astro'

const {fullName} = profile

const trimTrailingSlash = (value: string) =>
	value.length > 1 && value.endsWith('/') ? value.slice(0, -1) : value

const normalizePath = (path: string) => {
	const base = template.base && template.base !== '/' ? trimTrailingSlash(template.base) : ''
	let normalized = trimTrailingSlash(path || '/')

	if (base && normalized.startsWith(base)) {
		normalized = normalized.slice(base.length) || '/'
	}

	return normalized || '/'
}

const currentPath = normalizePath(Astro.url.pathname)

const navItems = [
	{ label: 'Home', href: `${template.base}/` },
	{ label: 'About', href: `${template.base}/about` },
	{ label: 'Projects', href: `${template.base}/projects` },
	{ label: 'Talks', href: `${template.base}/talks` },
	{ label: 'Music', href: `${template.base}/music` },
	{ label: 'Contact', href: `${template.base}/contact` },
]

const isActiveRoute = (href: string) => normalizePath(href) === currentPath
---
<aside
	class='px-4 pt-4 h-screen w-[20rem] bg-base-200 text-base-content flex flex-col'
	aria-label='Primary sidebar'
	data-ui='sidebar'
>
	<div class='flex flex-col my-8 justify-between h-full'>
		<div>
				<div class='flex justify-center items-center flex-col' data-ui='sidebar-profile'>
					<div class='size-44 rounded-full bg-[linear-gradient(135deg,#2af4ce_0%,#1de2bc_45%,#13c7a3_100%)] p-[3px] shadow-[0_0_1px_11px_rgba(29,226,188,0.2)]'>
						<Image
							class='navbar-image-static size-full rounded-full object-cover object-[center_20%]'
							src={ProfilePictures}
							alt={`Profile picture of ${fullName}`}
							data-ui='sidebar-profile-image'
						/>
					</div>
				<div class="mt-6 hidden lg:block text-center">
					<h1 class="text-base font-semibold tracking-tight text-base-content/90">
						{fullName}
					</h1>
					<p class="mt-1 text-sm font-medium tracking-wide text-base-content/60">
						Senior QA Automation Engineer
					</p>
				</div>
			</div>
			<div class='mx-auto mt-12 w-full max-w-[14.5rem]'>
				<ul class='menu grow shrink menu-md overflow-y-auto text-base' data-ui='sidebar-nav-list'>
					{navItems.map((item) => {
						const isActive = isActiveRoute(item.href)
						const itemToken = item.label.toLowerCase().replace(/[^a-z0-9]+/g, '-')

						return (
							<li class='mx-1 border-b border-base-content/15 first:border-t' data-ui={`sidebar-nav-item-${itemToken}`}>
								<a
									href={item.href}
									aria-current={isActive ? 'page' : undefined}
									data-ui={`sidebar-nav-link-${itemToken}`}
									class:list={[
										'menu-link px-2 py-2.5 text-[1.02rem] font-medium transition-colors duration-200 text-center justify-center',
										'focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:ring-offset-2 focus-visible:ring-offset-base-200',
										isActive
											? 'bg-success/10 text-success hover:bg-success/10'
											: 'text-base-content/75 hover:text-base-content',
									]}
								>
									{item.label}
								</a>
							</li>
						)
					})}
				</ul>
			</div>
		</div>
		<div class='mx-4'>
			<SocialIcons compact noWrap context='sidebar' />
		</div>
	</div>
</aside>

<style>
	.navbar-image-static {
		animation: none !important;
		transform: none !important;
		filter: none !important;
	}

	.menu-link {
		-webkit-tap-highlight-color: transparent;
	}

	.menu-link:active {
		background-color: hsl(var(--su) / 0.14) !important;
		color: hsl(var(--su)) !important;
	}
</style>
