---
import ProfilePictures from '@/assets/Douglas_2026.jpg'
import { template } from '@/settings'
import { Image } from 'astro:assets'
import { profile } from '../../settings'
import SocialIcons from './SocialIcons.astro'

const {fullName} = profile

const trimTrailingSlash = (value: string) =>
	value.length > 1 && value.endsWith('/') ? value.slice(0, -1) : value

const normalizePath = (path: string) => {
	const base = template.base && template.base !== '/' ? trimTrailingSlash(template.base) : ''
	let normalized = trimTrailingSlash(path || '/')

	if (base && normalized.startsWith(base)) {
		normalized = normalized.slice(base.length) || '/'
	}

	return normalized || '/'
}

const currentPath = normalizePath(Astro.url.pathname)

const navItems = [
	{ label: 'Home', href: `${template.base}/` },
	{ label: 'About', href: `${template.base}/about` },
	{ label: 'Projects', href: `${template.base}/projects` },
	{ label: 'Talks', href: `${template.base}/talks` },
	{ label: 'Music', href: `${template.base}/music` },
	{ label: 'Contact', href: `${template.base}/contact` },
]

const isActiveRoute = (href: string) => normalizePath(href) === currentPath
---
<aside
	class='h-[100dvh] max-h-[100dvh] w-[min(85vw,20rem)] lg:w-[20rem] bg-base-200 text-base-content flex flex-col px-4 pb-5 pt-4'
	aria-label='Primary sidebar'
	data-ui='sidebar'
>
	<div class='grid grid-cols-[auto_1fr_auto] items-center gap-2 border-b border-base-content/15 pb-2.5 lg:hidden' data-ui='sidebar-mobile-header'>
		<button
			type='button'
			aria-controls='my-drawer'
			aria-label='Close sidebar menu'
			class='btn btn-ghost btn-square btn-sm h-10 w-10 rounded-xl border border-success/35 bg-success/12 text-success shadow-[0_1px_0_rgba(16,185,129,0.22)] hover:bg-success/20 hover:text-success focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-success/40 focus-visible:ring-offset-1 focus-visible:ring-offset-base-200'
			data-ui='drawer-close-button'
		>
			<svg
				xmlns='http://www.w3.org/2000/svg'
				fill='none'
				viewBox='0 0 24 24'
				stroke-width='1.9'
				class='size-5 stroke-current'
			>
				<path stroke-linecap='round' stroke-linejoin='round' d='M15.75 19.5 8.25 12l7.5-7.5'></path>
			</svg>
		</button>
		<div class='flex min-w-0 items-center gap-2.5 px-1' data-ui='sidebar-mobile-identity'>
			<div class='size-10 shrink-0 rounded-full bg-[linear-gradient(135deg,#2af4ce_0%,#1de2bc_45%,#13c7a3_100%)] p-[2px]'>
				<Image
					class='navbar-image-static size-full rounded-full object-cover object-[center_20%]'
					src={ProfilePictures}
					alt={`Profile picture of ${fullName}`}
					data-ui='sidebar-profile-image'
				/>
			</div>
			<div class='min-w-0 leading-tight'>
				<p class='truncate text-[0.88rem] font-semibold text-base-content'>{fullName}</p>
				<p class='truncate text-[0.66rem] font-medium tracking-[0.04em] text-base-content/65'>Senior QA Automation Engineer</p>
			</div>
		</div>
		<div class='w-10' aria-hidden='true'></div>
	</div>

	<div class='flex h-full flex-col justify-between py-4 lg:my-8'>
		<div>
			<div class='hidden flex-col items-center lg:flex' data-ui='sidebar-profile'>
				<div class='size-44 rounded-full bg-[linear-gradient(135deg,#2af4ce_0%,#1de2bc_45%,#13c7a3_100%)] p-[3px] shadow-[0_0_1px_11px_rgba(29,226,188,0.2)]'>
					<Image
						class='navbar-image-static size-full rounded-full object-cover object-[center_20%]'
						src={ProfilePictures}
						alt={`Profile picture of ${fullName}`}
						data-ui='sidebar-profile-image'
					/>
				</div>
				<div class='mt-6 text-center'>
					<h1 class='text-base font-semibold tracking-tight text-base-content/90'>
						{fullName}
					</h1>
					<p class='mt-1 text-sm font-medium tracking-wide text-base-content/60'>
						Senior QA Automation Engineer
					</p>
				</div>
			</div>

			<div class='mx-auto mt-4 w-full max-w-[15rem] lg:mt-12 lg:max-w-[14.5rem]'>
				<ul class='menu grow shrink menu-md overflow-y-auto text-base' data-ui='sidebar-nav-list'>
					{navItems.map((item) => {
						const isActive = isActiveRoute(item.href)
						const itemToken = item.label.toLowerCase().replace(/[^a-z0-9]+/g, '-')

						return (
							<li class='mx-2 border-b border-base-content/15 first:border-t' data-ui={`sidebar-nav-item-${itemToken}`}>
								<a
									href={item.href}
									aria-current={isActive ? 'page' : undefined}
									data-ui={`sidebar-nav-link-${itemToken}`}
									class:list={[
										'menu-link px-2 py-2 text-[0.95rem] font-medium transition-colors duration-200 text-center justify-center',
										'focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:ring-offset-2 focus-visible:ring-offset-base-200',
										isActive
											? 'bg-success/10 text-success hover:bg-success/10'
											: 'text-base-content/75 hover:text-base-content',
									]}
								>
									{item.label}
								</a>
							</li>
						)
					})}
				</ul>
			</div>
		</div>

		<div class='mx-3 border-t border-base-content/15 pt-3.5 lg:mx-4 lg:pt-4' data-ui='sidebar-social-container'>
			<SocialIcons compact noWrap context='sidebar' />
		</div>
	</div>
</aside>

<style>
	.navbar-image-static {
		animation: none !important;
		transform: none !important;
		filter: none !important;
	}

	.menu-link {
		-webkit-tap-highlight-color: transparent;
	}

	.menu-link:active {
		background-color: hsl(var(--su) / 0.14) !important;
		color: hsl(var(--su)) !important;
	}
</style>
