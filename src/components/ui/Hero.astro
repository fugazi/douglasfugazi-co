---
import { Image } from 'astro:assets'

import SocialIcons from './SocialIcons.astro'


const {fullName, title, institute, profilePicture} = Astro.props
---
<div class='hero-copy flex-1' data-ui='hero-copy'>
  <h1 class='text-3xl xl:text-4xl leading-tight font-bold mb-4'>
    <span class='block'>Welcome!</span>
    <span class='block'>
      I'm <span class='text-success md:whitespace-nowrap'>{fullName}</span>.
    </span>
  </h1>
  <p class='text-xl text-base-content/80 mb-4'>{title}{institute ? ` at ${institute}` : ''}</p>
  <p class='text-lg mb-4'>
   I hold an MSc in Technology Management and certifications in ISTQB Foundation and Certified Scrum Master, helping organizations ship faster, safer, and at scale through strategic automated testing across the full STLC.
  </p>
  <p class='text-lg mb-6'>
    With over 14 years of experience, I build robust Playwright and Selenium frameworks powered by AI-driven testing for global teams.
  </p>
  <div class='flex gap-4'>
    <SocialIcons context='hero' />
  </div>
</div>
<div class='hero-photo hidden lg:block shrink-0' data-ui='hero-photo'>
  <div class='size-64 xl:size-72 rounded-full bg-[linear-gradient(135deg,#2af4ce_0%,#1de2bc_45%,#13c7a3_100%)] p-[5px] shadow-[0_0_1px_14px_rgba(29,226,188,0.22)]'>
    <div class='size-full rounded-full overflow-hidden bg-base-100'>
      <Image
        src={profilePicture}
        alt={`Portrait of ${fullName}`}
        class='hero-image-static w-full h-full object-cover object-[center_20%]'
        data-ui='hero-profile-image'
      />
    </div>
  </div>
</div>

<style>
  .hero-copy {
    animation-name: heroDropIn;
    animation-duration: 860ms;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    animation-fill-mode: both;
    will-change: transform, opacity;
  }

  .hero-copy {
    animation-delay: 70ms;
  }

  .hero-image-static {
    animation: none !important;
    transform: none !important;
    filter: none !important;
  }

  @keyframes heroDropIn {
    from {
      opacity: 0;
      transform: translate3d(0, -14px, 0);
    }
    70% {
      opacity: 1;
      transform: translate3d(0, 1px, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-copy {
      animation: none;
    }
  }
</style>
