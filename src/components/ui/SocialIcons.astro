---
import Bandcamp from '@/assets/social-icons/bandcamp.svg'
import Envelope from '@/assets/social-icons/envelope.svg'
import GitHub from '@/assets/social-icons/github.svg'
import Instagram from '@/assets/social-icons/instagram.svg'
import LinkedIn from '@/assets/social-icons/linkedin-in.svg'

import { social } from '@/settings'

const { compact = false, noWrap = false } = Astro.props

const orderedSocial = [
	{ href: social.linkedin, label: 'LinkedIn', Icon: LinkedIn },
	{ href: social.github, label: 'GitHub', Icon: GitHub },
	{ href: social.instagram, label: 'Instagram', Icon: Instagram },
	{ href: social.bandcamp, label: 'Bandcamp', Icon: Bandcamp },
	{ href: social.email ? `mailto:${social.email}` : '', label: 'Email', Icon: Envelope },
].filter(({ href }) => href !== '')

const calculatedIconSize = compact ? 'size-5' : orderedSocial.length <= 5 ? 'size-6' : 'size-5'
const calculatedContainerSize = compact ? 'size-10' : orderedSocial.length <= 5 ? 'size-12' : 'size-10'
const wrapClass = noWrap ? 'flex-nowrap' : 'flex-wrap'
const gapClass = compact ? 'gap-1.5' : 'gap-2'
---

<div class={`flex items-center ${wrapClass} ${gapClass}`}>
	{
		orderedSocial.map(({ href, label, Icon }) => (
			<a
				href={href}
				target='_blank'
				rel='noopener noreferrer'
				aria-label={label}
				title={label}
				class={`${calculatedContainerSize} inline-flex items-center justify-center rounded-xl text-base-content/80 hover:bg-success/20 hover:text-success transition-all duration-300`}
			>
				<Icon class={calculatedIconSize} fill='currentColor' />
			</a>
		))
	}
</div>
