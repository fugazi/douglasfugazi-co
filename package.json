{
  "name": "douglasfugazi-co",
  "type": "module",
  "version": "1.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint --config tests/.eslintrc.cjs \"tests/**/*.ts\"",
    "format": "prettier --config tests/.prettierrc.json --write \"tests/**/*.ts\" .github/workflows/*.yml",
    "format:check": "prettier --config tests/.prettierrc.json --check \"tests/**/*.ts\" .github/workflows/*.yml",
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:e2e": "playwright test --grep @e2e",
    "test:a11y": "playwright test --grep @a11y",
    "test:integration": "playwright test --grep @integration",
    "test:visual": "playwright test --grep @visual",
    "test:ci": "pnpm run lint && pnpm run format:check && pnpm exec tsc --noEmit && pnpm run build && pnpm run test"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/tailwind": "^5.1.5",
    "astro": "5.18.1",
    "tailwindcss": "^3.4.19",
    "theme-change": "^2.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "axe-core": "^4.11.3",
    "daisyui": "^4.12.24",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.1",
    "prettier": "^3.8.2",
    "sharp": "^0.34.5"
  }
}
